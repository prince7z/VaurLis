# Environment
NODE_ENV=development
PORT=5000

# Frontend URL (update this when deploying)
FRONTEND_URL=http://localhost:5173

# Backend API URL (for frontend to connect)
VITE_API_URL=http://localhost:5000

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/Coursera
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/VaurLis

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Razorpay Configuration (for payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET_KEY=your_razorpay_secret_key

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Logtail Configuration (for logging)
LOGTAIL_SOURCE_TOKEN=your_logtail_source_token

# SendGrid Configuration (for email services)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=your_verified_sender_email@example.com
